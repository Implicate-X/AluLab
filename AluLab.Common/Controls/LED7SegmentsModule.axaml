			BorderThickness="1">
		<Canvas>
			<Polygon x:Name="SegA" Points="10.626,4.252 23.429,4.252 27.193,1.093 26.100,0.000 9.072,0.000 7.977,1.095 10.626,4.252" Fill="#FF4080FF"/>
			<Polygon x:Name="SegB" Points="23.884,4.795 21.567,17.938 23.491,20.048 25.717,18.888 28.605,2.505 27.696,1.596 23.884,4.795" Fill="#FF4080FF"/>
