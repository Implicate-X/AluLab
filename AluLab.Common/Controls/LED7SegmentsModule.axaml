			<Polygon x:Name="SegD" Points="17.909,36.056 5.107,36.056 1.295,39.255 2.033,40.308 19.463,40.308 20.558,39.213 17.909,36.056" Fill="#FF4080FF"/>
			<Polygon x:Name="SegE" Points="4.651,35.513 7.271,22.201 5.386,20.052 3.033,21.740 0.000,37.406 0.887,38.672 4.651,35.513" Fill="#FF4080FF"/>
			<Polygon x:Name="SegF" Points="5.495,19.344 7.830,17.599 10.083,4.707 7.474,1.598 6.066,3.006 3.546,17.294 5.495,19.344" Fill="#FF4080FF"/>
			<Polygon x:Name="SegG" Points="21.077,18.453 8.330,18.081 5.982,19.809 8.091,22.147 20.413,22.493 22.813,20.340 21.077,18.453" Fill="#FF4080FF"/>
